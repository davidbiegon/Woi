<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My GitHub Website</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background-color: #f4f4f4;
            text-align: center;
        }

        header {
            background: darkblue;
            color: white;
            padding: 20px;
        }

        nav {
            background: #222;
            padding: 10px;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin: 15px;
        }

        section {
            padding: 40px;
        }

        button {
            padding: 10px 20px;
            background: darkblue;
            color: white;
            border: none;
            cursor: pointer;
        }

        footer {
            background: #222;
            color: white;
            padding: 15px;
            margin-top: 30px;
        }
    </style>
</head>
<body>

    <header>
        <h1>Welcome to My Website</h1>
        <p>Hosted on GitHub Pages</p>
    </header>

    <nav>
        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Contact</a>
    </nav>

    <section>
        <h2>About This Site</h2>
        <p>This website is created using only one HTML file.</p>
        <button onclick="showMessage()">Click Me</button>
    </section>

    <footer>
        <p>© 2026 My Website</p>
    </footer>

    <script>
        function showMessage() {
            alert("Your website is working successfully!");
        }
    </script>

</body>
</html>
